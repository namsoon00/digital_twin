{
  "name": "digital_twin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check": "node --check public/app.js && node --check scripts/smoke-test.js && node --check scripts/share-local.js && node --check scripts/issue-workflow.js && node --check scripts/stamp-flutter-web-build.js && node --check scripts/generate-static-mock-market.js && npm run python:check",
    "dev": "python3 python_service/service.py web",
    "generate:admin-preview": "python3 python_service/service.py admin-preview",
    "generate:mock-market": "node scripts/generate-static-mock-market.js",
    "generate:static": "npm run generate:mock-market && npm run generate:admin-preview",
    "issue:claim": "node scripts/issue-workflow.js claim",
    "issue:done": "node scripts/issue-workflow.js done",
    "issue:export": "node scripts/issue-workflow.js export",
    "issue:fail": "node scripts/issue-workflow.js fail",
    "issue:list": "node scripts/issue-workflow.js list",
    "issue:watch": "node scripts/issue-workflow.js watch",
    "python:accounts": "python3 python_service/service.py accounts",
    "python:check": "python3 -m compileall -q python_service/service.py python_service/monitor_service.py python_service/digital_twin python_service/tests",
    "python:handoff": "python3 python_service/service.py handoff",
    "python:handoff:notify": "python3 python_service/service.py handoff notify",
    "python:monitor": "python3 python_service/service.py monitor",
    "python:monitor:message-types": "python3 python_service/service.py monitor message-types",
    "python:monitor:once": "python3 python_service/service.py monitor once",
    "python:monitor:send-types": "python3 python_service/service.py monitor send-types",
    "python:monitor:status": "python3 python_service/service.py monitor status",
    "python:monitor:watch": "python3 python_service/service.py monitor watch",
    "python:market-data:once": "python3 python_service/service.py market-data once",
    "python:market-data:status": "python3 python_service/service.py market-data status",
    "python:market-data:watch": "python3 python_service/service.py market-data watch",
    "python:news:once": "python3 python_service/service.py news once",
    "python:news:status": "python3 python_service/service.py news status",
    "python:news:watch": "python3 python_service/service.py news watch",
    "python:model-review:once": "python3 python_service/service.py model-review once",
    "python:model-review:status": "python3 python_service/service.py model-review status",
    "python:model-review:watch": "python3 python_service/service.py model-review watch",
    "python:notifications:once": "python3 python_service/service.py notifications once",
    "python:notifications:status": "python3 python_service/service.py notifications status",
    "python:notifications:watch": "python3 python_service/service.py notifications watch",
    "python:ontology-reasoning:once": "python3 python_service/service.py ontology-reasoning once",
    "python:ontology-reasoning:status": "python3 python_service/service.py ontology-reasoning status",
    "python:ontology-reasoning:watch": "python3 python_service/service.py ontology-reasoning watch",
    "python:ontology:seed": "python3 python_service/service.py ontology seed",
    "python:symbols:refresh": "python3 python_service/service.py symbols refresh",
    "python:symbols:search": "python3 python_service/service.py symbols search",
    "python:symbols:status": "python3 python_service/service.py symbols status",
    "python:templates": "python3 python_service/service.py templates",
    "python:service": "python3 python_service/monitor_service.py",
    "python:service:restart": "python3 python_service/monitor_service.py restart",
    "python:service:start": "python3 python_service/monitor_service.py start",
    "python:service:status": "python3 python_service/monitor_service.py status",
    "python:service:stop": "python3 python_service/monitor_service.py stop",
    "python:test": "OPERATIONAL_DB_BACKEND=sqlite python3 -m unittest discover -s python_service/tests",
    "share": "node scripts/share-local.js",
    "smoke": "node scripts/smoke-test.js",
    "stamp:flutter-web": "node scripts/stamp-flutter-web-build.js",
    "start": "python3 python_service/service.py web",
    "test": "npm run check && npm run smoke && npm run python:test"
  },
  "dependencies": {
    "cytoscape": "^3.34.0"
  },
  "devDependencies": {}
}
