    "python:monitor:once": "python3 python_service/service.py monitor once",
    "python:monitor:status": "python3 python_service/service.py monitor status",
    "python:monitor:watch": "python3 python_service/service.py monitor watch",
    "python:service": "python3 python_service/monitor_service.py",
    "python:service:restart": "python3 python_service/monitor_service.py restart",
    "python:service:start": "python3 python_service/monitor_service.py start",
    "python:service:status": "python3 python_service/monitor_service.py status",
    "python:service:stop": "python3 python_service/monitor_service.py stop",
    "python:test": "python3 -m unittest discover -s python_service/tests",
    "share": "node scripts/share-local.js",
    "smoke": "node scripts/smoke-test.js",
    "stamp:flutter-web": "node scripts/stamp-flutter-web-build.js",
