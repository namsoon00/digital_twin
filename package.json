    "issue:fail": "node scripts/issue-workflow.js fail",
    "issue:list": "node scripts/issue-workflow.js list",
    "issue:watch": "node scripts/issue-workflow.js watch",
    "notify": "node scripts/notify-worker.js --once",
    "notify:realtime": "node scripts/notify-realtime-service.js start",
    "notify:realtime:daemon": "node scripts/notify-worker.js --realtime-daemon",
    "notify:realtime:once": "node scripts/notify-worker.js --realtime",
    "notify:realtime:restart": "node scripts/notify-realtime-service.js restart",
    "notify:realtime:status": "node scripts/notify-realtime-service.js status",
    "notify:realtime:stop": "node scripts/notify-realtime-service.js stop",
    "notify:telegram-chat": "node scripts/notify-worker.js --telegram-chat-ids",
    "notify:watch": "node scripts/notify-worker.js --daemon",
    "python:accounts": "python3 python_service/service.py accounts",
    "python:check": "python3 -m compileall -q python_service/service.py python_service/monitor_service.py python_service/digital_twin python_service/tests",
