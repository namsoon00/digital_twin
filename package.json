  "scripts": {
    "check": "node --check server.js && node --check public/app.js && node --check scripts/smoke-test.js && node --check scripts/share-local.js && node --check scripts/issue-workflow.js && node --check scripts/notify-worker.js && node --check scripts/notify-realtime-service.js && node --check scripts/stamp-flutter-web-build.js && node --check scripts/generate-static-mock-market.js && npm run python:check",
    "dev": "node server.js",
    "generate:mock-market": "node scripts/generate-static-mock-market.js",
    "issue:claim": "node scripts/issue-workflow.js claim",
